# Raw scraped data contains personal data (names, LinkedIn, photos) — never publish.
data/*.jsonl
data/*.csv

# Single-campus JSON lists employer names — keep only the fully-aggregate one.
data/report.json

# Only the aggregate, anonymous report JSON is safe to publish.
!data/report_all.json

# Raw capture bodies contain personal data — publish only their HASHES
# (in provenance/manifest.json) and the no-PII header/witness files.
capture/**/*.body.json

# All-tracks RAW DATA + per-track findings — kept PRIVATE for now (not published).
# The tamper-evidence PROOF (provenance_all/) and the scripts ARE committed, so the
# capture is publicly time-anchored even though the underlying data stays private.
capture_all/
data_all/

# junk
__pycache__/
.DS_Store

# Operational notification letters — kept local (do not tip off the target publicly)
notifications/

# Articles + Reddit kits/comments — stratégie de diffusion, gardée en local
article/
